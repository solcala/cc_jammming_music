{
  "name": "cc_jammming_music",
  "homepage": "https://solcala.github.io/cc_jammming_music/",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "gh-pages": "^6.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "^5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "test": "react-scripts test",
    "test:e2e": "playwright test",
    "test:e2e:ci": "mkdir -p test-results && CI_SERVE_BUILD=true playwright test",
    "test:api": "playwright test e2e/api",
    "test:ui": "playwright test e2e/ui",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "mkdir -p test-results && CI=true npm test -- --coverage --watchAll=false --json --outputFile=test-results/jest.json",
    "eject": "react-scripts eject",
    "postinstall": "patch-package",
    "lint": "eslint src e2e --max-warnings 0",
    "test:all": "npm run test:coverage && npm run build && npm run test:e2e:ci"
  },
  "overrides": {
    "nth-check": "^2.1.1",
    "postcss": "^8.4.49",
    "path-to-regexp": "^0.1.12",
    "nanoid": "^3.3.11",
    "http-proxy-middleware": "^2.0.9",
    "webpack-dev-server": "^5.2.4",
    "brace-expansion": "^2.0.2",
    "on-headers": "^1.1.0",
    "form-data": "^3.0.4",
    "js-yaml": "^3.14.2",
    "glob": "^10.5.0",
    "test-exclude": "^7.0.1",
    "@jest/reporters": {
      "glob": "^7.2.3"
    },
    "node-forge": "^1.3.2",
    "qs": "^6.14.1",
    "lodash": "^4.17.23"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "e2e/**/*.ts",
          "e2e/**/*.tsx"
        ],
        "rules": {
          "testing-library/prefer-screen-queries": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 65,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/jest": "^27.5.2",
    "eslint": "^8.57.1",
    "eslint-plugin-testing-library": "^6.5.0",
    "patch-package": "^8.0.0",
    "serve": "^14.2.4",
    "typescript": "^4.9.5"
  }
}
