# Spotify API credentials
# Get these from https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Redirect URI must match exactly what you register in the Spotify Dashboard.
# Spotify does not allow "localhost" — use the loopback IP 127.0.0.1 instead.
# Open the app at http://127.0.0.1:3000/cc_jammming_music/ (not localhost).
VITE_REDIRECT_URI=http://127.0.0.1:3000/cc_jammming_music/
