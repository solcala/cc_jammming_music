# Spotify API credentials (public client — PKCE, no client secret)
# Get yours at https://developer.spotify.com/dashboard
REACT_APP_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# Must match a Redirect URI registered in the Spotify Dashboard (unchanged for PKCE).
# After login Spotify redirects here with ?code= in the query string (not #access_token in the hash).
REACT_APP_REDIRECT_URI=http://localhost:3000

# Slack Incoming Webhook (optional — local dry-run only)
# CI uses the SLACK_WEBHOOK_URL GitHub repository secret instead.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
